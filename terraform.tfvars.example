# terraform.tfvars.example
# -------------------------
# Copy this file to terraform.tfvars and fill in YOUR values.
# terraform.tfvars is gitignored so your specifics never get committed.
#
# NOTE: When running via the GitHub Actions pipeline, these are supplied through
# a committed terraform.tfvars OR via TF_VAR_* env vars in the workflow. For the
# demo the simplest path is to commit a terraform.tfvars with non-secret values
# (owner/repo/region are not secrets).

region        = "us-east-1"
project_name  = "oidc-demo"
github_owner  = "your-github-username" # e.g. devopswithjunaid
app_repo_name = "sample-app"           # the APPLICATION repo, not aws-infra
app_port      = 8080

# For a quick demo, leave this open so you can curl the task. For anything real,
# restrict to your own IP, e.g. ["203.0.113.4/32"].
allowed_cidr_blocks = ["0.0.0.0/0"]
