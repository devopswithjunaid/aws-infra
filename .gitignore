# Terraform
.terraform/
# NOTE: .terraform.lock.hcl is intentionally COMMITTED (not ignored) so the
# pipeline's plan and apply jobs use identical, reproducible provider versions.
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Your real variable values (owner/repo/region are not secrets, but keep local
# copies out of git; commit terraform.tfvars.example instead).
terraform.tfvars

# Plan output artifacts
tfplan
*.tfplan
